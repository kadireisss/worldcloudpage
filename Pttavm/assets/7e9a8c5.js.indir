(window.webpackJsonp=window.webpackJsonp||[]).push([[140],{1858:function(e,n,t){"use strict";t.r(n);t(10),t(9),t(8),t(12),t(13);var l=t(4),r=t(888),d={name:"AccordionMenu",props:{data:{type:Array,required:!0}},methods:{changeActiveStatus:function(e){e.active=!e.active}}},m=t(5),o=Object(m.a)(d,(function(){var e=this,n=e.$createElement,t=e._self._c||n;return t("div",{staticClass:"accordion-menu"},e._l(e.data,(function(n,l){return t("div",{key:l,staticClass:"accordion-parent mb-10"},[t("div",{staticClass:"accordion-parent-title w-full flex items-center text-xl mb-4"},[t("span",{staticClass:"text-2xl mr-2",class:n.icon}),e._v(" "+e._s(n.title)+"\n    ")]),e._v(" "),e._l(n.children,(function(n,r){return t("div",{key:l+"_"+r,staticClass:"accordion-child"},[t("div",{staticClass:"accordion-child-title bg-eGrey-200 hover:bg-eGrey-300 transition-all duration-100 text-base px-4 py-2 mb-3 cursor-pointer rounded-md",on:{click:function(t){return e.changeActiveStatus(n)}}},[e._v("\n        "+e._s(n.title)+"\n      ")]),e._v(" "),t("div",{directives:[{name:"show",rawName:"v-show",value:n.active,expression:"child.active"}],staticClass:"accordion-child-content mb-3 text-sm border-eGrey-200 border border-solid p-3 rounded-md",domProps:{innerHTML:e._s(n.content)}})])}))],2)})),0)}),[],!1,null,"0c9cf82a",null).exports,c=t(0),k=t(6);function v(object,e){var n=Object.keys(object);if(Object.getOwnPropertySymbols){var t=Object.getOwnPropertySymbols(object);e&&(t=t.filter((function(e){return Object.getOwnPropertyDescriptor(object,e).enumerable}))),n.push.apply(n,t)}return n}function y(e){for(var i=1;i<arguments.length;i++){var source=null!=arguments[i]?arguments[i]:{};i%2?v(Object(source),!0).forEach((function(n){Object(l.a)(e,n,source[n])})):Object.getOwnPropertyDescriptors?Object.defineProperties(e,Object.getOwnPropertyDescriptors(source)):v(Object(source)).forEach((function(n){Object.defineProperty(e,n,Object.getOwnPropertyDescriptor(source,n))}))}return e}var z={name:"SıkcaSorulanSorular",components:{CategoryTree:r.a,AccordionMenu:o},mixins:[c.a],computed:y(y({},Object(k.c)({settings:"settings",isResponsive:"isResponsive"})),{},{metaTitle:function(){return"Sıkça Sorulan Sorular - "+this.settings.siteTitleShort}}),data:function(){return{categories:[{name:"Sıkça Sorulan Sorular",url:"sikca-sorulan-sorular.html"}],faqData:[]}},mounted:function(){var e=this;window.scrollTo(0,0),this.faqData=[{icon:"eptticon-helper-user-plus",title:"Üyelik",children:[{title:"Nasıl Üye Olurum?",content:'<div><p class="mb-2">'.concat(this.settings&&this.settings.siteURLShort,' üyeliği ücretsizdir. Üyelik formunu doldurarak siteye kolay ve güvenli bir şekilde kaydolabilirsiniz.</p><p class="mb-2"><a href="').concat("https://www.pttavm.com",'/uye-ol" class="font-semibold">Üyelik için tıklayınız.</a></p><p class="mb-2">Üye olmak için aşağıdaki adımları izleyin:</p><ul class="mb-3 pl-10 list-disc"><li>Ana sayfanın sağ üst köşesinde bulunan <span class="font-semibold">Yeni Üye</span> linkini tıklayın.</li><li>Üyelik formunu doldurun, aktif olarak kullandığınız bir e-posta adresi yazın, şifre oluşturun.</li><li>Formu doldurduktan sonra <span class="font-semibold">Üye Ol</span> butonuna basın.</li></ul><p>Tebrikler! Üyelik İşlemini Gerçekleştirdiniz.</p></div>'),active:!1},{title:"Üyelik Aktivasyon Kodum Gelmedi, Ne Yapabilirim?",content:"<div>Aktivasyon kodunuz gelmedi ise giriş yapmaya çalıştıktan sonra aktivasyon kodu gönder butonuna tıklayarak tekrar gönderilmesini sağlayabilirsiniz. Sorun yaşamaya devam ediyorsanız iletişim formu doldurarak bize ulaşabilirsiniz.</div>",active:!1},{title:"Üyelik Bilgilerimi Nasıl Güncelleyebilirim?",content:'<div>Mevcut e-posta ve şifreniz ile siteye giriş yaparak sağ üst köşede isminizin bulunduğu alanda yer alan <a href="'.concat("https://www.pttavm.com",'/my/bilgi" class="font-semibold">Kişisel Bilgiler</a> bölümünden bilgilerinizi değiştirebilirsiniz.</div>'),active:!1},{title:"Şifremi Unuttum Ne Yapmalıyım?",content:'<div>Ana sayfadaki <a href="'.concat("https://www.pttavm.com",'/giris-yap" class="font-semibold">Üye Girişi</a> alanına tıkladığınızda karşınıza gelen ekranda yer alan "Şifremi Unuttum" bölümüne tıkladığınızda açılan ekranda e-posta adresinizi belirterek yeni şifrenizi alabilirsiniz.</div>'),active:!1},{title:"Kampanya Duyuru e-Postalarını Nasıl İptal Edebilirim?",content:'<div>Sistemde kayıtlı olan mail adresinize gönderilmiş e-postayı almak istemiyorsanız, gönderilmiş olan kampanya görselinin sağ alt kısmında bulunan <span class="font-semibold">Üyelikten Ayrıl</span> alanından işlemlerinizi gerçekleştirebilirsiniz. İşlemlerinizde yine de sorun yaşıyorsanız iletişim formu doldurarak mail almak istemediğinize dair talepte bulunabilirsiniz.</div>',active:!1},{title:"Üyeliğimi Nasıl İptal Edebilirim?",content:"<div>Web sayfamızdaki ya da mobil uygulamamızdaki iletişim bölümünden bu talebinizle ilgili form doldurabilirsiniz.</div>",active:!1},{title:"Teslimat Bilgilerimi Nasıl Güncellerim?",content:"<div>Siparişinizi vermeden önce teslimat adresinizi dilediğiniz gibi seçip sisteme kaydedebilirsiniz. Sisteme en fazla 10 farklı teslimat adresi kaydedebilirsiniz. Eğer siparişinizi verdikten sonra teslimat adresinizi değiştirmek isterseniz siparişiniz ‘Hazırlık Aşamasında’ olduğu süreç içerisinde web sayfamızdan yada mobil uygulamamızdan İletişim formu doldurarak talebinizi iletebilirsiniz.</div>",active:!1},{title:"Hesabım Sayfasından Yapabileceğim İşlemler Nelerdir?",content:'<div><p class="mb-2">Hesabım sayfasından,</p><ul class="pl-10 list-disc"><li>Şifrenizi değiştirebilir</li><li>Teslimat adres bilgilerinizi güncelleyebilir.</li><li>Sepetinize attığınız ürünleri yönetebilir ve sipariş geçmişini görebilir.</li><li>Ürün iade işlemlerinizi yapabilir.</li><li>Müşteri hizmetleri birimimize ulaşabilirsiniz.</li></ul></div>',active:!1}]},{icon:"eptticon-helper-cart",title:"Alışveriş İşlemleri",children:[{title:"Nasıl Ürün Alabilirim?",content:'<div>Üye girişinizi yapınız. Mevcut kategoriler içinden satın almak istediğiniz ürünü seçiniz ve <span class="font-semibold">Sepete At</span> butonuna basınız. Ardından ödeme yöntemini, adres bilgilerinizi seçin ve alışverişinizi tamamlayın.</div>',active:!1},{title:"Sipariş Takibi Nasıl Yapılmaktadır?",content:'<div>Siparişinizin takibini üye isminizin üzerine tıklayarak <a href="'.concat("https://www.pttavm.com",'/my/siparis-takip" class="font-semibold">Sipariş Takibi</a> alanından ya da sipariş numaranız ile <a href="https://gonderitakip.ptt.gov.tr" class="font-semibold" target="_blank">Ptt Gönderi Takip</a> adresinden yapabilirsiniz.</div>'),active:!1},{title:"Hemen Al Seçeneği Nedir?",content:'<div>Üye girişinizi yapınız. Mevcut kategoriler içinden satın almak istediğiniz ürünü seçiniz ve <span class="font-semibold">Hemen Al</span> butonuna basınız. Ardından ödeme yöntemini, adres bilgilerinizi seçin ve alışverişinizi tamamlayın.</div>',active:!1}]},{icon:"eptticon-helper-user-plus",title:"Üyeliksiz Alışveriş İşlemleri",children:[{title:"Üye olmadan alışveriş yapabilir miyim?",content:"<div>".concat(this.settings&&this.settings.siteTitleShort,"’dan üye olmadan da hızlı ve güvenli bir şekilde alışveriş yapabilirsiniz. Üye olmadan yapacağınız alışverişlerde size kargo durumunuzu bildirebilmemiz için mail adresi girmeniz zorunludur. Ayrıca sipariş esnasında faturaya yazılması için TC kimlik numarası girilmesi yasal zorunluluktur.</div>"),active:!1},{title:"Üye olmadan alışveriş yapmanın faydaları nelerdir?",content:"<div>Üye olmadan alışveriş yapmak isteyen kişiler için tasarlanmıştır. Üye olmadan alışveriş yapmak hem hızlı bir alışveriş imkanı tanır. Ayrıca şifrelerini unutan kullanıcılar farklı bir mail adresi girmek koşulu ile alışverişlerini gerçekleştirebilirler.</div>",active:!1},{title:"Üye olmadan yapılan alışverişlerde iptal ve iade nasıl yapılır?",content:"<div>Üye olmadan yaptığınız alışverişlerinizin iptal ve iadesi için web sayfamızda ve mobil uygulamalarımızda bulunan İletişim formunu doldurarak talep iletmeniz gerekmektedir.</div>",active:!1},{title:"Üye olmadan yapılan alışverişlerden sonra yapılan üyeliklerde sipariş detayları görünür mü?",content:"<div>Üyeliksiz yaptığınız alışverişleri üye olduktan sonra sipariş detay sayfasında göremezsiniz.</div>",active:!1},{title:"Üye olmadan verilen siparişin takibi nasıl yapılır?",content:'<div>Üye olmadan alışveriş yapmak için vermiş olduğunuz mail adresine göndermiş olduğumuz sipariş takip numarası ile <a href="'.concat("https://www.pttavm.com",'/my/siparisler" class="font-semibold">Sipariş Takip</a> sayfasında takip edebilirsiniz.</div>'),active:!1},{title:"Üye olanların ne gibi avantajları bulunmaktadır?",content:"<div>Üye olarak yapacağınız alışverişlerde üyelerimize özel tanımlanan indirim, kampanya ve hediye çeklerinden yararlanabilirsiniz.</div>",active:!1}]},{icon:"eptticon-helper-credit-card",title:"Ödeme ve Güvenlik İşlemleri",children:[{title:"3D Secure Nedir ve Nasıl Kullanılır?",content:"<div>Tüm dünyada online alışverişlerde bir standart halini alan 3D Secure ile ".concat(this.settings&&this.settings.siteTitleShort,"‘ da güvenli şekilde alışveriş yapabilirsiniz. Visa ve Mastercard tarafından geliştiren 3D Secure sistemi, ödeme işlemi sırasında kartınızın sahibi olan bankanın web sitesine yönlendirilerek kredi kartınıza ait şifre ile onaylama işlemi gerçekleştirilebilmektedir. İnternet üzerindeki alışverişlerin güvenliği arttırması amacıyla geliştirilmiştir.</div>"),active:!1},{title:"3D Secure Neden Güvenlidir?",content:"<div>3D Secure sisteminde, sanal ödeme işlemi gerçekleşirken, banka tarafından kart sahibine sadece kendisinin bildiği ödeme şifresi sorulmakta ve kart sahibinin kimliği doğrulanmaktadır. Yetkisiz kişilerin kartlarının internet ortamında kullanımını engellemektedir.</div>",active:!1},{title:"Alışveriş esnasında kullandığım kredi kartından bilgim dışında tahsilat yapılır mı?",content:"<div>".concat(this.settings&&this.settings.siteTitleShort,"’dan yaptığınız alışverişlerde kredi kartı bilgileriniz kesinlikle saklanmaz. 3D Secure sistemi ile kart bilgilerinizi bankanıza göndermiş olursunuz. Bu nedenle isteğiniz ve bilginiz dışında kesinlikle tahsilat yapılmaz.</div>"),active:!1},{title:"Alışverişlerimi hangi ödeme yöntemleri ile ödeyebilirim?",content:"<div>".concat(this.settings&&this.settings.siteTitleShort,"’dan yaptığınız alışverişleri kapıda ödeme seçeneği ile ödeyebilirsiniz. Bunun dışında tüm banka kartları ve kredi kartlarından, ticari kartlardan, Havale/EFT, BKM Express ya da Garanti Pay ile ödeyebilirsiniz.</div>"),active:!1},{title:"Neden TC Kimlik No talep ediliyor?",content:"<div>29/08/2006 tarihli, <u>26274 sayılı Resmi Gazete</u>’de tebliğ edildiği üzere 1/1/2007 tarihinden itibaren gerçek kişilere kesilen faturalarda T.C. Kimlik Numarası yazma zorunluluğu getirilmiştir. Bu sebeple üyelik esnasından T.C. Kimlik Numarası istenmektedir.</div>",active:!1}]},{icon:"eptticon-helper-undo",title:"İptal ve İade İşlemleri",children:[{title:"Siparişimi nasıl iptal edebilirim?",content:"<div>Yaptığınız alışverişlerinizin iptali için web sayfamızda ve mobil uygulamalarımızda bulunan İletişim formunu doldurarak talep iletmeniz gerekmektedir.</div>",active:!1},{title:"Siparişimi nasıl iade edebilirim?",content:'<div>Siparişinizi iade etmek için <a href="'.concat("https://www.pttavm.com",'/sayfa/urun-iade-proseduru.html" class="font-semibold">Ürün İade Prosedürü</a>\'ne tıklayınız</div>'),active:!1},{title:"İade prosedürü nedir?",content:"<div>Almış olduğunuz ürünü iade edebilmeniz ve ödediğini ücretin size iade edilebilmesi için gereken adımlardır.</div>",active:!1},{title:"Siparişim neden iptal edilmiş?",content:'<div><p class="mb-2">Bankanızın gerekli durumlarda, siparişinizi teyit etmek adına size ait bir telefon numarasına ulaşamaması durumunda, siparişinizi kredi kartı sahibinin güvenliğini sağlamak amacı ile iptal edebilmektedir. Sipariş iptali ile ilgili bilgiler, sipariş sahibinin üyeliğinde kayıtlı e-posta adresine gönderilir. Siparişinizin banka tarafından onay alabilmesi için, bankanızda ve sitemizde kayıtlı kişisel bilgilerinizin güncellenmiş olması gerekmektedir.</p><p>Ayrıca <span class="font-semibold">Kapıda Ödeme</span> seçilerek gerçekleştirilen siparişlerde, sipariş esnasında belirttiğiniz numaranızdan ulaşılarak <span class="font-semibold">Sipariş Onayı</span> alınmaktadır. Kayıtlı numaranıza ulaşılamadığı durumlarda sizlere kayıtlı mail adresinizden bilgi verilmekte ve siparişinizin onaylanması için süre tanımlanmaktadır.</p></div>',active:!1},{title:"Cayma hakkı nedir ve nasıl kullanırım?",content:'<div><p class="mb-2">Cayma hakkı ürün bazlı olup ürününüz elinize ulaştıktan sonra 14 gün içerisinde koşulsuz iade hakkınız bulunmaktadır.</p><p>Satın olmuş olduğunuz ürünü iade edebilmek için, üye girişi yaptıktan sonra <a href="'.concat("https://www.pttavm.com",'/my/siparisler" class="font-semibold">Sipariş Takip</a> sayfasını kullanarak iade kodu almanız ve bu kodla birlikte size en yakın PTT şubesine ürünün kutusu ve faturası ile birlikte eksiksiz olarak teslim etmeniz gerekmektedir.</p></div>'),active:!1},{title:"Aldığım ürünü kullandım iade edebilir miyim?",content:"<div>Ürünün mutat kullanımı, cayma hakkını ortadan kaldırmaz. Satıcı, cayma süresi içinde ürünü alıcıya teslim etmişse alıcı, ürünü ancak olağan bir gözden geçirmenin gerektirdiği ölçüde kullanabilir. Aksi takdirde alıcı cayma hakkını kullanamaz. Ürünün değerinin azalması veya iadeyi imkânsızlaşması alıcının kusurundan kaynaklanıyorsa, alıcının, ürünün değerini veya değerindeki azalmayı satıcıya tazmin etmesi gerekir. Bu durumda, satıcı zararınızı tazmin edebilmek için, ürün değerinin azalmasına ilişkin alıcı hakkında yasal yollara başvurabilir.</div>",active:!1},{title:"Cayma hakkı sürecinde kargo ücreti kime aittir?",content:"<div>Cayma hakkı sürecinde kargo ücreti satıcıya aittir.</div>",active:!1},{title:"Cayma hakkının geçerli olmadığı durumlar nelerdir?",content:'<div><p class="mb-2">Aşağıda belirtilen ürünlerin iade işlemi yapılamamaktadır.</p><p class="mb-2">Alıcının isteği ile kişiye özel olarak üretilen, üzerinde değişiklik veya ilave yapılarak kişiye özel hale getirilen ürünler.</p><p class="mb-2">Niteliği itibarıyla geri gönderilmeye elverişli olmayan ürünler (İç çamaşırı, mayo, kozmetik gibi hijyenik durumu hassas olan ürünleri iade edebilmenin koşulu ürünün açılmamış ve denenmemiş olmasıdır.)</p><p class="mb-2">Alıcı tarafından açılmış olan ses veya görüntü kayıtları (DVD, CD ve Kaset vb.), basılı ürünler (Kitap, dergi vb.), yazılım programları ve bilgisayar sarf malzemeleri</p><p class="mb-2">Çabuk bozulma tehlikesi olan veya son kullanma tarihi geçme ihtimali olan ürünler</p><p class="mb-2">Fiyatı borsa veya teşkilatlanmış diğer piyasalarda belirlenen ürünler (Külçe, Ziynet Altın ve Gümüş kategorisindeki tüm ürünler vb.)</p></div>',active:!1},{title:"Faturam ulaşmadı ne yapabilirim?",content:"<div>Sipariş esnasında faturanızı başka bir adrese isteyip istemediğinizi kontrol ediniz. Eğer faturanızı ürün ile aynı adrese talep ettiyseniz ve elinize ulaşmadıysa lütfen web sayfamızda ve mobil uygulamamızda bulunan İletişim formunu doldurarak bizlere bildiriniz.</div>",active:!1}]},{icon:"eptticon-helper-truck",title:"Kargo ve Teslimat İşlemleri",children:[{title:"Siparişim hangi kargo şirketi ile gönderilir?",content:"<div>Tüm alışverişleriniz %100 Ptt Kargo güvencesi ile gönderilmektedir.</div>",active:!1},{title:"Kargomu nasıl takip edebilirim?",content:'<div>Siparişinizin takibini üye isminizin üzerine tıklayarak <a href="'.concat("https://www.pttavm.com",'/my/siparisler" class="font-semibold">Sipariş Geçmişi</a> alanından ya da <a href="http://gonderitakip.ptt.gov.tr" class="font-semibold">http://gonderitakip.ptt.gov.tr</a> adresinden ürün barkod numarası ile yapabilirsiniz.</div>'),active:!1},{title:"Kargo takip numarasına nereden ulaşabilirim?",content:"<div>Kargo takip numaranız alışverişinizi tamamlamanızın ardından gönderilen mailde sizinle paylaşılmaktadır. Ayrıca bu numarayı Sipariş Geçmişim sayfasından da öğrenebilirsiniz.</div>",active:!1},{title:"Kargoda ürüne zarar gelmesi durumunda sorumluluk kime aittir?",content:"<div>Ürünün kargo paketinde ya da üründe fark edilir şekilde hasar, kırık, darbe teslim edilmesi halinde kargo görevlisine mutlaka ‘Hasar Tespit Raporu’ düzenletmelisiniz. Hasarlı kargolar için kargo görevlileri zabıt tutmakla yükümlüdür. Kargo görevlisinin Zabıt, tutanak ve ya belge düzenlemediği durumlarda ürünü teslim almadan kargo görevlisine iade edebilir veya kargo şubesinde ürünün kontrolünü sağlayarak teslim alabilirsiniz. Hasar tespit belgesini düzenletmezseniz üründeki sorunun kargo ya da mağaza kaynaklı olduğunu ispat etmeniz mümkün değildir. Bu nedenle mutlaka tutanak tutturmalısınız.</div>",active:!1},{title:"Alışverişler yurtdışına gönderiliyor mu?",content:"<div>".concat(this.settings&&this.settings.siteTitleShort," üzerinden yapmış olduğunuz alışverişler Türkiye’nin 81 iline gönderilmekte olup yurtdışına henüz gönderim yapılmamaktadır.</div>"),active:!1},{title:"Sipariş teslim süresi ne kadardır?",content:"<div>Sipariş teslimatı ilgili mağazaların ürünleri kargoya teslim etmesini takiben 3 iş günü içerisinde gerçekleştirilecektir.</div>",active:!1},{title:"İade kargo ücretleri kim tarafından karşılanıyor?",content:"<div>İade kargo ücretleri satıcı tarafından karşılanır.</div>",active:!1}]}],this.$nextTick((function(){e.$gtm.pageView({pagePath:e.$route,pageTitle:e.metaTitle})}))},head:function(){return{title:this.metaTitle,meta:[{hid:"description",name:"description",content:this.settings.siteTitleShort+" Sıkça Sorulan Sorular"}],link:[{rel:"canonical",href:this.getCanonicalUrl()}]}}},f=Object(m.a)(z,(function(){var e=this,n=e.$createElement,t=e._self._c||n;return t("div",{staticClass:"flex flex-col pt-2"},[t("div",{staticClass:"container md:px-4 xl:px-0"},[t("category-tree",{attrs:{withHomePage:"",items:e.categories,prefix:"/sayfa"}}),e._v(" "),e.isResponsive?e._e():t("line-break",{staticClass